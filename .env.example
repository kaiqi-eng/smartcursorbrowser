PORT=3000
SERVICE_API_KEY=replace-with-strong-api-key
OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4.1-mini
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=smartcursorbrowser
MAX_JOB_STEPS=25
JOB_TIMEOUT_MS=1800000
AI_TIMEOUT_MS=1800000
EXTRACTION_TIMEOUT_MS=1800000
TEARDOWN_TIMEOUT_MS=1800000
ALLOWED_DOMAINS=

# Optional override for Otter jobs: if both are set, they replace request email/password.
OTTER_LOGIN_EMAIL=
OTTER_LOGIN_PASSWORD=

# Oxylabs fallback credentials (used when browser flow fails to satisfy goal)
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
OXYLABS_REQUEST_TIMEOUT_MS=30000
OXYLABS_ARTICLE_FETCH_TIMEOUT_MS=15000
